# ============================================================
# VARIABLES D'ENVIRONNEMENT BACKEND — Copier en .env
# Ne JAMAIS committer le vrai .env — ce fichier est un modèle
# ============================================================

# JWT — Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REMPLACER_PAR_CLE_ALEATOIRE_64_CHARS
JWT_KEY_SECRET=REMPLACER_PAR_CLE_ALEATOIRE_64_CHARS
REFRESH_TOKEN_SECRET=REMPLACER_PAR_CLE_ALEATOIRE_64_CHARS

# Chiffrement données sensibles (32 bytes exactement)
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=REMPLACER_PAR_CLE_32_BYTES_EXACTEMENT

# Email (utiliser Firebase Extensions ou un service dédié en prod — NE PAS utiliser Gmail perso)
EMAIL=votre-email@domaine.com
EMAIL_PASSWORD=MOT_DE_PASSE_APPLICATION_GMAIL

# Webhook
WEBHOOK_GLOBAL_SECRET=REMPLACER_PAR_SECRET_ALEATOIRE

# Firebase (optionnel si utilisation de admin.json — préférer variables d'env en prod)
FIREBASE_PROJECT_ID=votre-projet-firebase

# Environnement
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
